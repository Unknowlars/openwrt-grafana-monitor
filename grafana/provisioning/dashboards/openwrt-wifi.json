{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "OpenWRT Router — WiFi Clients & Signal Quality",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Connected Clients",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\"}) or vector(0)",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Avg Signal Strength",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -75 },
              { "color": "green", "value": -60 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "avg(wifi_station_signal_dbm{job=\"openwrt\"})",
          "legendFormat": "Avg Signal",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "2.4 GHz Clients",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\", ifname=~\"wlan0.*\"}) or vector(0)",
          "legendFormat": "2.4 GHz",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5 GHz Clients",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\", ifname=~\"wlan1.*\"}) or vector(0)",
          "legendFormat": "5 GHz",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connected WiFi Clients Over Time",
      "id": 5,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "min": 0
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\", ifname=~\"wlan0.*\"}) or vector(0)",
          "legendFormat": "2.4 GHz clients",
          "refId": "A"
        },
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\", ifname=~\"wlan1.*\"}) or vector(0)",
          "legendFormat": "5 GHz clients",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Client Signal Strength (RSSI)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -75 },
              { "color": "green", "value": -60 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "wifi_station_signal_dbm{job=\"openwrt\"}",
          "legendFormat": "{{ mac }} ({{ ifname }})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WiFi Interface RX/TX",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"openwrt\", device=~\"wlan.*\"}[$__rate_interval])",
          "legendFormat": "RX {{ device }}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"openwrt\", device=~\"wlan.*\"}[$__rate_interval])",
          "legendFormat": "TX {{ device }}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "table",
      "title": "Connected Clients — Details",
      "id": 8,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Signal (dBm)" },
            "properties": [
              { "id": "unit", "value": "dBm" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": -75 },
                    { "color": "green", "value": -60 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "desc": false, "displayName": "Signal (dBm)" }] },
      "targets": [
        {
          "expr": "wifi_station_signal_dbm{job=\"openwrt\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "mac": "MAC Address",
              "ifname": "Interface",
              "Value": "Signal (dBm)"
            },
            "excludeByName": { "Time": true, "__name__": true, "job": true, "router": true }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openwrt"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenWRT — WiFi",
  "uid": "openwrt-wifi",
  "version": 1
}
