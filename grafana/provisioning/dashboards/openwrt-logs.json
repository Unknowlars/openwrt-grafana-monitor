{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "OpenWRT Router — System Logs & Events",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Errors (last 1h)",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count_over_time({job=\"openwrt-syslog\"} |= \"error\" [1h])",
          "legendFormat": "Errors",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warnings (last 1h)",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 20 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count_over_time({job=\"openwrt-syslog\"} |= \"warn\" [1h])",
          "legendFormat": "Warnings",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DHCP Events (last 1h)",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count_over_time({job=\"openwrt-syslog\"} |= \"DHCP\" [1h])",
          "legendFormat": "DHCP",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Firewall Drops (last 1h)",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count_over_time({job=\"openwrt-syslog\"} |= \"DROP\" [1h])",
          "legendFormat": "Drops",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Log Lines (last 1h)",
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "gray", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "expr": "count_over_time({job=\"openwrt-syslog\"}[1h])",
          "legendFormat": "Lines",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Log Rate by Type",
      "id": 6,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate({job=\"openwrt-syslog\"} |= \"error\" [$__rate_interval]))",
          "legendFormat": "Errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate({job=\"openwrt-syslog\"} |= \"warn\" [$__rate_interval]))",
          "legendFormat": "Warnings",
          "refId": "B"
        },
        {
          "expr": "sum(rate({job=\"openwrt-syslog\"} |= \"DHCP\" [$__rate_interval]))",
          "legendFormat": "DHCP events",
          "refId": "C"
        },
        {
          "expr": "sum(rate({job=\"openwrt-syslog\"} |= \"DROP\" [$__rate_interval]))",
          "legendFormat": "Firewall drops",
          "refId": "D"
        }
      ]
    },
    {
      "type": "logs",
      "title": "All System Logs",
      "id": 7,
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"openwrt-syslog\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "DHCP Events",
      "id": 8,
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"openwrt-syslog\"} |= \"DHCP\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Firewall Events (DROP / REJECT)",
      "id": 9,
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"openwrt-syslog\"} |~ \"DROP|REJECT\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openwrt"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenWRT — Logs",
  "uid": "openwrt-logs",
  "version": 1
