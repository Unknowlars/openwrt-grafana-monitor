{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "OpenWRT Router — System Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Network",
      "type": "link",
      "url": "/d/openwrt-network",
      "icon": "external link",
      "tooltip": "Network deep dive"
    },
    {
      "title": "WiFi",
      "type": "link",
      "url": "/d/openwrt-wifi",
      "icon": "external link",
      "tooltip": "WiFi clients"
    },
    {
      "title": "Logs",
      "type": "link",
      "url": "/d/openwrt-logs",
      "icon": "external link",
      "tooltip": "System logs"
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Uptime",
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "node_time_seconds{job=\"openwrt\"} - node_boot_time_seconds{job=\"openwrt\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Used",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes{job=\"openwrt\"} / node_memory_MemTotal_bytes{job=\"openwrt\"})",
          "legendFormat": "Memory Used",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "CPU Load (1m)",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "node_load1{job=\"openwrt\"}",
          "legendFormat": "Load 1m",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "WiFi Clients",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "count(wifi_station_signal_dbm{job=\"openwrt\"}) or vector(0)",
          "legendFormat": "Clients",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "NAT Sessions",
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "node_nf_conntrack_entries{job=\"openwrt\"}",
          "legendFormat": "NAT Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Free Memory",
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20971520 },
              { "color": "green", "value": 52428800 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"openwrt\"}",
          "legendFormat": "Free Memory",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WAN Throughput",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RX (download)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "TX (upload)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"openwrt\", device=\"eth0\"}[$__rate_interval])",
          "legendFormat": "RX (download)",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"openwrt\", device=\"eth0\"}[$__rate_interval])",
          "legendFormat": "TX (upload)",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Load Average",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_load1{job=\"openwrt\"}",
          "legendFormat": "1 minute",
          "refId": "A"
        },
        {
          "expr": "node_load5{job=\"openwrt\"}",
          "legendFormat": "5 minutes",
          "refId": "B"
        },
        {
          "expr": "node_load15{job=\"openwrt\"}",
          "legendFormat": "15 minutes",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "min": 0
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"openwrt\"} - node_memory_MemAvailable_bytes{job=\"openwrt\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"openwrt\"}",
          "legendFormat": "Available",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "NAT Conntrack Sessions",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_nf_conntrack_entries{job=\"openwrt\"}",
          "legendFormat": "Active sessions",
          "refId": "A"
        },
        {
          "expr": "node_nf_conntrack_entries_limit{job=\"openwrt\"}",
          "legendFormat": "Limit",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openwrt"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenWRT — Overview",
  "uid": "openwrt-overview",
  "version": 1
}
