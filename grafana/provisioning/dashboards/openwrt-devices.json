        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(node_network_transmit_bytes_total{job=\"openwrt\", device=\"phy0-ap0\"}[$__rate_interval])",
