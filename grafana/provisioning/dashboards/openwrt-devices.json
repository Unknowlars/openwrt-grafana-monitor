        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(router_device_up{job=\"openwrt\"} == 0)",
          "legendFormat": "Offline",
          "refId": "B"
