    {
      "type": "bargauge",
      "id": 6,
      "title": "Top Devices by NAT Traffic (bytes)",
      "description": "Top 10 LAN clients by total NAT traffic bytes (current snapshot, not rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "topk(10, sum by(src)(node_nat_traffic{job=\"openwrt\"}))",
          "legendFormat": "{{src}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
