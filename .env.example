# OpenWRT Grafana Monitor — Configuration
# Copy this file to .env and edit the values

# ── Router ────────────────────────────────────────────────────────────────────
# IP address of your OpenWRT router
ROUTER_IP=192.168.0.1

# A friendly name for the router (used as a Grafana label)
ROUTER_NAME=openwrt

# Port where prometheus-node-exporter-lua listens on the router
ROUTER_METRICS_PORT=9100

# How often to scrape metrics from the router
SCRAPE_INTERVAL=30s

# ── Monitoring host ────────────────────────────────────────────────────────────
# IP of the machine running this Docker stack (used by the router to send syslog)
# The router's `log_ip` UCI setting should point here
MONITORING_HOST_IP=192.168.0.100

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme

# ── Syslog receiver ───────────────────────────────────────────────────────────
# Port Alloy listens on for syslog from the router (UDP + TCP)
SYSLOG_PORT=514
